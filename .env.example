# Copy to `.env` (or export in your shell) and fill in your own credentials.
# The evaluation pipeline uses Qwen3-VL-Plus as an LLM judge through the
# DashScope OpenAI-compatible API.

# DashScope API key for the evaluation judge.
DASHSCOPE_API_KEY=

# Optional: force fully-offline model loading once weights are cached locally.
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1

# Optional: HuggingFace mirror endpoint (useful in some regions).
# HF_ENDPOINT=https://hf-mirror.com
