{
    "model_name": "BAGEL-7B-MoT",
    "model_path": "ByteDance-Seed/BAGEL-7B-MoT",
    "api_type": "bagel",
    "conda_env": "bagel",
    "inference_function": {
        "module": "bagel_inference",
        "function": "bagel_inference_function"
    },
    "bagel_project_path": "/path/to/Unified_Models/Bagel",
    "mode": 1,
    "gpu_id": 0,
    
