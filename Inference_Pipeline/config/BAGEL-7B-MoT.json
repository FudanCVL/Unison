    "image_shapes": [512, 512],
    "cfg_text_scale": 4.0,
    "cfg_img_scale": 1.5,
    "cfg_interval": [0.4, 1.0],
    "num_timesteps": 50,
    "timestep_shift": 3.0,
    "cfg_renorm_min": 0.0,
    "cfg_renorm_type": "global",
    
    "description": "BAGEL-7B-MoT model config. inference_mode options: understanding (image understanding), generation (image generation), editing (image editing)"
